<?xml version="1.0" encoding="utf-8"?>
<!-- Экран галереи с ImageView и кнопками навигации -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".GalleryActivity">

    <!-- ImageView для отображения фото -->
    <ImageView
        android:id="@+id/imageImageView1"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scaleType="fitCenter"
        android:contentDescription="Фотография" />

    <!-- Информация о фото -->
    <TextView
        android:id="@+id/tvImageInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Информация"
        android:textSize="14sp"
        android:gravity="center"
        android:padding="8dp"
        android:layout_marginBottom="16dp" />

    <!-- Кнопки навигации -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Кнопка ПРЕДЫДУЩЕЕ -->
        <Button
            android:id="@+id/bPrevious"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⬅️ ПРЕДЫДУЩЕЕ"
            android:layout_marginEnd="8dp" />

        <!-- Кнопка СЛЕДУЮЩЕЕ -->
        <Button
            android:id="@+id/bNext"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="СЛЕДУЮЩЕЕ ➡️"
            android:layout_marginStart="8dp" />

    </LinearLayout>

</LinearLayout>